@page "/"
@using APS.Shared
@using Microsoft.AspNetCore.SignalR.Client
@using MudBlazor

@inject NavigationManager Navigation
@implements IAsyncDisposable

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 pa-4">
    <h1 class="mud-text-h3 mud-text-primary mb-2">📊 Plataforma de Monitoramento Ambiental</h1>
    <p class="mud-text-subtitle1 mb-6">Rio Tietê - Secretaria de Estado do Meio Ambiente</p>

    <MudGrid Spacing="4">
        <MudItem xs="12" md="6">
            <MudCard>
                <MudCardHeader><CardHeaderContent><MudText Typo="Typo.h6">Status do Servidor</MudText></CardHeaderContent></MudCardHeader>
                <MudCardContent>
                    <MudText Color="Color.Success">✅ TCP Server Online - Porta 5000</MudText>
                    <MudText>Clientes conectados: <strong>@_clientsCount</strong></MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="6">
            <MudAlert Severity="@_alertSeverity" Variant="Variant.Filled">@_lastAlert</MudAlert>
        </MudItem>

        <MudItem xs="12">
            <MudTextField @bind-Value="_searchTerm" Label="🔎 Filtrar por Indústria" Variant="Variant.Outlined" Class="mb-4" />
        </MudItem>

        <MudItem xs="12">
            <MudCard>
                <MudCardHeader>
                    <MudText Typo="Typo.h5">📥 Dados Recebidos em Tempo Real</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudTable Items="@FilteredData" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Indústria</MudTh>
                            <MudTh>Poluição (mg/L)</MudTh>
                            <MudTh>pH</MudTh>
                            <MudTh>Temp (°C)</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Hora</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.IndustryName</MudTd>
                            <MudTd>@context.PollutionLevel</MudTd>
                            <MudTd>@context.Ph</MudTd>
                            <MudTd>@context.Temperature</MudTd>
                            <MudTd>
                                <MudChip T="string" Color="@(context.Status == "Alerta" ? Color.Warning : Color.Success)">
                                    @context.Status
                                </MudChip>
                            </MudTd>
                            <MudTd>@context.Timestamp.ToString("HH:mm:ss")</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private HubConnection? _hubConnection;
    private List<EnvironmentalData> _dataList = new();
    private string _lastAlert = "Aguardando dados...";
    private Severity _alertSeverity = Severity.Info;
    private int _clientsCount = 0;
    private string _searchTerm = "";

    private IEnumerable<EnvironmentalData> FilteredData =>
        string.IsNullOrWhiteSpace(_searchTerm)
            ? _dataList
            : _dataList.Where(d => d.IndustryName.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/environmentalHub"))
            .Build();

        _hubConnection.On<EnvironmentalData>("ReceiveEnvironmentalData", data =>
        {
            _dataList.Insert(0, data);
            if (_dataList.Count > 50) _dataList.RemoveAt(50);
            _clientsCount++;
            StateHasChanged();
        });

        _hubConnection.On<string>("ReceiveAlert", msg =>
        {
            _lastAlert = msg;
            _alertSeverity = Severity.Error;
            StateHasChanged();
        });

        await _hubConnection.StartAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
            await _hubConnection.DisposeAsync();
    }
}